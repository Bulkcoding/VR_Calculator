generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String?
  kakaoId   String?  @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  holdings          Holding[]
  vrStrategies      VrStrategy[]
  brokerCredentials BrokerCredential[]
  watchlist         WatchlistItem[]
}

model WatchlistItem {
  id        String   @id @default(cuid())
  userId    String
  ticker    String
  name      String
  market    String?
  currency  String   @default("KRW")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ticker])
  @@index([userId])
}

model Holding {
  id           String   @id @default(cuid())
  userId       String
  ticker       String
  name         String
  quantity     Float
  avgPrice     Float
  currentPrice Float?
  currency     String   @default("KRW")
  market       String?
  broker       String   @default("manual")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  vrStrategies VrStrategy[]
  vrCycles    VrCycle[]
  snapshots   Snapshot[]

  @@unique([userId, ticker])
}

model VrStrategy {
  id           String   @id @default(cuid())
  holdingId    String
  userId       String
  vValue       Float
  bandPreset   Int      @default(15)
  bandPct      Float    @default(0.15)
  divisorG     Int      @default(10)
  contribution Float    @default(0)
  withdrawal   Float    @default(0)
  pool         Float    @default(0)
  currentQty   Float
  mode         String   @default("lump")
  tradeUnit    Int      @default(1)
  advanced     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  holding Holding @relation(fields: [holdingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([holdingId])
}

model VrCycle {
  id           String   @id @default(cuid())
  holdingId    String
  cycleNumber  Int
  startDate    DateTime @default(now())
  endDate      DateTime?
  mode         String   @default("lump")

  vValue       Float
  bandPreset   Int      @default(15)
  bandPct      Float
  divisorG     Int
  contribution Float    @default(0)
  withdrawal   Float    @default(0)
  tradeUnit    Int      @default(1)
  advanced     Boolean  @default(false)

  startPool    Float?
  endPool      Float?
  startEval    Float?
  endEval      Float?
  startQty     Float?
  endQty       Float?
  startPrice   Float?
  endPrice     Float?
  minBand      Float?
  maxBand      Float?

  notes        String?
  createdAt    DateTime @default(now())

  holding Holding @relation(fields: [holdingId], references: [id], onDelete: Cascade)

  @@unique([holdingId, cycleNumber])
  @@index([holdingId])
}

model Snapshot {
  id          String   @id @default(cuid())
  holdingId   String
  evaluatedAt DateTime @default(now())
  vValue      Float
  pool        Float
  currentQty  Float
  minBand     Float
  maxBand     Float
  data        Json?

  holding Holding @relation(fields: [holdingId], references: [id], onDelete: Cascade)
}

model BrokerCredential {
  id           String @id @default(cuid())
  userId       String
  broker       String
  encryptedKey String
  label        String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, broker])
}
